{
  "name": "sfz.dev",
  "version": "2.0.0",
  "description": "sforzando LLC. Official Website - Built with Hugo and Congo theme",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "format": "npm run check:biome && npm run format:html",
    "check:biome": "biome check --write .",
    "format:html": "prettier --write '**/*.html'",
    "lint": "biome lint ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sforzando/sfz.dev.git"
  },
  "keywords": [
    "hugo",
    "congo",
    "website",
    "static-site"
  ],
  "author": "sforzando LLC. and Inc.",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sforzando/sfz.dev/issues"
  },
  "homepage": "https://github.com/sforzando/sfz.dev#readme",
  "dependencies": {
    "mapbox-gl": "^3.22.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "dotenv": "^17.4.2",
    "lefthook": "^2.1.6",
    "lighthouse": "^13.1.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "prettier-plugin-go-template": "^0.0.15",
    "serve": "^14.2.6",
    "typescript": "^6.0.3"
  }
}
